# Server configuration (copy to .env and fill real values)
PORT=
MONGO_URI=
JWT_SECRET=
CLIENT_URL=

# Login protection
# Per-IP request throttle applies to all login posts.
LOGIN_RATE_WINDOW_MINUTES=
LOGIN_RATE_MAX_REQUESTS_PER_IP=
# Failed login lockouts are tracked by IP + login ID/email + role.
# Failed attempts accumulate until a successful login or a temporary block.
USER_LOGIN_MAX_FAILURES=
USER_LOGIN_BLOCK_MINUTES=
ADMIN_LOGIN_MAX_FAILURES=
ADMIN_LOGIN_BLOCK_MINUTES=

# Admin / app secrets
ADMIN_SECRET=
DEFAULT_ENCRYPTION_SECRET=
DEFAULT_ENCRYPTION_SALT=
REVIEW_CHAT_TOTP_SECRET=
REVIEW_CHAT_TOTP_PERIOD_SECONDS=
REVIEW_CHAT_UNLOCK_TTL_SECONDS=

# Email (Brevo / SMTP)
BREVO_API_KEY=
ADMIN_EMAIL=
EMAIL_FROM_NAME=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_USER=
EMAIL_PASS=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MOCK=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUD_NAME=
API_KEY=
API_SECRET=

# LLM provider (optional)
GROQ_API_KEY=
